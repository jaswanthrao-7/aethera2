# -----------------------------------------------------------------------------
# AETHERA COGNITIVE ELIXIR - ENV PROTOCOLS TEMPLATE
# Copy this file to '.env.local' to activate local DB and Auth hubs.
# -----------------------------------------------------------------------------

# MongoDB Connection String
# For local MongoDB, use: mongodb://127.0.0.1:27017/aethera_db
# For production (MongoDB Atlas), use: mongodb+srv://<user>:<password>@cluster.mongodb.net/aethera
MONGODB_URI=mongodb://127.0.0.1:27017/aethera_db

# JSON Web Token Secret Key
# Generate a highly complex secure key for production
JWT_SECRET=aethera-super-secret-quantum-crypto-key-2026

# Node Environment state
NODE_ENV=development
